# Track only AdoDAS project versions from this home repo.
# Everything else in /home/adodas stays local by default.
*
!.gitignore
!AdoDAS2026*/
!AdoDAS2026*/**

# Local backups after converting nested repos to monorepo (do not push)
**/.git.nested_backup_*/

# Python/cache/build artifacts
**/__pycache__/
**/*.py[cod]
**/*.pyo
**/*.pyd
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/.ipynb_checkpoints/
**/*.egg-info/
**/build/
**/dist/
**/cmake-build-*/
**/CMakeFiles/
**/CMakeCache.txt

# Local environments and editor state
**/.venv/
**/venv/
**/env/
**/ENV/
**/conda_env/
**/.vscode/
**/.idea/
**/.DS_Store
**/wandb/
**/tensorboard/

# Keep AdoDAS code/config/log/csv/json outputs, but do not upload large ML artifacts.
**/checkpoints/
**/weights/
**/pretrained/
**/cache/
**/manifests_cache/
**/*.pt
**/*.pth
**/*.ckpt
**/*.bin
**/*.safetensors
**/*.onnx
**/*.bmodel
**/*.engine
**/*.tflite

# Large feature/data/intermediate files
**/*.npy
**/*.npz
**/*.parquet
**/*.pkl
**/*.pickle
**/*.joblib
**/*.h5
**/*.hdf5
**/*.lmdb
**/*.sqlite
**/*.db
**/*.zip
**/*.tar
**/*.tar.gz
**/*.tgz
**/*.gz
**/*.rar
**/*.7z
**/*.wav
**/*.mp3
**/*.mp4
**/*.avi
**/*.mov
**/*.mkv

# Secrets and private machine config
**/.env
**/.env.*
**/*.pem
**/*.key
**/id_rsa
**/id_rsa.pub
**/id_ed25519
**/id_ed25519.pub
**/config.local.yaml
**/config_private.yaml
**/secrets.yaml
